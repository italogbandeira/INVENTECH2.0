/// Gerador do cliente Prisma.
/// O client é gerado dentro de app/generated/prisma.
generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

/// Fonte de dados principal.
/// Apesar de o provider ser mysql, ele também atende MariaDB nesse contexto.
datasource db {
  provider = "mysql"
}

/// Tabela usada como base temporária/importação bruta de máquinas.
/// Provavelmente serve como staging antes da normalização nas tabelas finais.
model base_maquinas_import {
  id                            Int     @id @default(autoincrement())
  numero_serie                  String? @db.VarChar(255)
  setor                         String? @db.VarChar(255)
  usuario                       String? @db.VarChar(255)
  tipo_equipamento              String? @db.VarChar(255)
  modelo                        String? @db.VarChar(255)
  contrato                      String? @db.VarChar(255)
  origem                        String? @db.VarChar(255)
  observacoes                   String? @db.Text
  login_email                   String? @db.VarChar(255)
  login_maquina                 String? @db.VarChar(255)
  esset                         String? @db.VarChar(50)
  termo_responsabilidade        String? @db.VarChar(50)
  numero_termo_responsabilidade String? @db.VarChar(255)
}

/// Tabela de contratos disponíveis para vincular às máquinas.
model contratos {
  id   Int    @id @default(autoincrement())
  nome String @unique(map: "nome") @db.VarChar(150)
}

/// Tabela principal de máquinas do sistema.
///
/// Observação:
/// Existem chaves estrangeiras implícitas no banco via IDs,
/// mas neste schema ainda não foram modeladas todas as relações Prisma.
model maquinas {
  id                            Int     @id @default(autoincrement())
  numero_serie                  String  @unique(map: "uq_maquinas_numero_serie") @db.VarChar(255)
  setor_id                      Int
  usuario_id                    Int?
  tipo_equipamento_id           Int?
  modelo_id                     Int?
  contrato_id                   Int?
  origem_id                     Int?
  observacoes                   String? @db.Text
  esset                         String? @db.VarChar(50)
  termo_responsabilidade        String? @db.VarChar(50)
  numero_termo_responsabilidade String? @db.VarChar(255)

  @@index([contrato_id], map: "fk_maquinas_contrato")
  @@index([modelo_id], map: "fk_maquinas_modelo")
  @@index([origem_id], map: "fk_maquinas_origem")
  @@index([setor_id], map: "fk_maquinas_setor")
  @@index([tipo_equipamento_id], map: "fk_maquinas_tipo")
  @@index([usuario_id], map: "fk_maquinas_usuario")
}

/// Funcionários que acessam o sistema.
/// Inclui autenticação e perfil de permissão.
model Funcionario {
  id            Int            @id @default(autoincrement())
  nome          String         @db.VarChar(150)
  email         String         @unique @db.VarChar(150)
  senhaHash     String         @map("senha_hash") @db.VarChar(255)
  ativo         Boolean        @default(true)
  perfil        String         @default("operador") @db.VarChar(50)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  /// Relação reversa com logs de auditoria.
  auditoriaLogs AuditoriaLog[]

  @@map("funcionarios")
}

/// Catálogo de modelos de equipamento.
model modelos {
  id   Int    @id @default(autoincrement())
  nome String @unique(map: "nome") @db.VarChar(150)
}

/// Catálogo de origens.
model origens {
  id   Int    @id @default(autoincrement())
  nome String @unique(map: "nome") @db.VarChar(100)
}

/// Catálogo de setores.
model setores {
  id   Int    @id @default(autoincrement())
  nome String @unique(map: "nome") @db.VarChar(100)
}

/// Catálogo de tipos de equipamento.
model tipos_equipamento {
  id   Int    @id @default(autoincrement())
  nome String @unique(map: "nome") @db.VarChar(100)
}

/// Usuários finais que recebem/vinculam máquinas.
/// Não são os mesmos "funcionários" que fazem login no sistema.
model usuarios {
  id            Int     @id @default(autoincrement())
  nome          String  @db.VarChar(150)
  login_email   String? @db.VarChar(150)
  login_maquina String? @db.VarChar(150)
}

/// Log de auditoria do sistema.
///
/// Armazena:
/// - entidade afetada
/// - ação executada
/// - responsável
/// - descrição legível
/// - estado antes/depois da mudança
model AuditoriaLog {
  id              Int          @id @default(autoincrement())
  entidade        String       @db.VarChar(50)
  entidadeId      Int?         @map("entidade_id")
  acao            String       @db.VarChar(50)

  funcionarioId   Int?         @map("funcionario_id")
  funcionarioNome String?      @map("funcionario_nome") @db.VarChar(150)

  descricao       String?      @db.Text
  antes           String?      @db.Text
  depois          String?      @db.Text

  createdAt       DateTime     @default(now()) @map("created_at")

  funcionarioRef  Funcionario? @relation(fields: [funcionarioId], references: [id])

  @@index([funcionarioId])
  @@index([entidade, entidadeId])
  @@index([createdAt])

  @@map("auditoria_logs")
}

/// Documentos anexados a um usuário.
///
/// Cada registro representa um arquivo salvo no storage local,
/// com o caminho relativo para acesso.
model UsuarioDocumento {
  id          Int      @id @default(autoincrement())
  usuarioId   Int      @map("usuario_id")
  tipo        String   @db.VarChar(100)
  nomeArquivo String   @map("nome_arquivo") @db.VarChar(255)
  caminho     String   @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([usuarioId])
  @@index([tipo])
  @@map("usuarios_documentos")
}